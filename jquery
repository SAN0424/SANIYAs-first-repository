<!DOCTYPE html> 
<html> 
<head> 
    <title>Mini Amazon</title> 
    <!-- jQuery Mobile --> 
    <link rel="stylesheet" href="https://code.jquery.com/mobile/1.4.5/jquery.mobile
1.4.5.min.css"> 
    <script src="https://code.jquery.com/jquery-1.11.3.min.js"></script> 
    <script src="https://code.jquery.com/mobile/1.4.5/jquery.mobile-1.4.5.min.js"></script> 
    <link rel="stylesheet" href="style.css"> 
    <meta name="viewport" content="width=device-width, initial-scale=1"> 
</head> 
<body> 
<!-- ================= HOME PAGE ================= --> 
<div data-role="page" id="home"> 
    <!-- Header --> 
    <div class="amazon-header"> 
        <h2>amazon.in</h2> 
        <input type="text" placeholder="Search products..." class="search-box"> 
    </div> 
 
    <!-- Navbar --> 
    <div data-role="navbar"> 
        <ul> 
            <li><a href="#home" class="ui-btn-active">Home</a></li> 
            <li><a href="#cart">Cart</a></li> 
            <li><a href="#about">About</a></li> 
        </ul> 
    </div> 
   
    <div data-role="content"> 
        <!-- Banner --> 
        <div class="home-banner"> 
            <h3>   Today's Deals</h3> 
            <p>Up to 50% OFF on Electronics</p> 
        </div> 
        <!-- Products --> 
        <div class="product-grid"> 
            <div class="product"> 
                <img src="images/speaker.jpg"> 
                <h4>Speaker</h4> 
                <p>₹15000</p> 
                <button onclick="addToCart('Speaker',15000)">Add to Cart</button> 
            </div> 
            <div class="product"> 
                <img src="images/headphone.jpg"> 
                <h4>Headphones</h4> 
                <p>₹2000</p> 
                <button onclick="addToCart('Headphones',2000)">Add to Cart</button> 
            </div> 
            <div class="product"> 
                <img src="images/watch.jpg"> 
                <h4>Smart Watch</h4> 
                <p>₹3000</p> 
                <button onclick="addToCart('Smart Watch',3000)">Add to Cart</button> 
            </div> 
            <div class="product"> 
                <img src="images/laptop.png"> 
                <h4>Laptop</h4> 
                <p>₹55000</p> 
                <button onclick="addToCart('Laptop',55000)">Add to Cart</button> 
            </div> 
        </div> 
    </div> 
    <!-- Footer --> 
    <div class="footer"> 
        <p><b>Mini Amazon</b></p> 
        <p>Electronics | Fashion | Deals</p> 
        <p>© 2026 All rights reserved</p> 
    </div> 
</div> 
<!-- ================= CART PAGE ================= --> 
<div data-role="page" id="cart"> 
    <div data-role="header" data-theme="b"> 
        <h1>Your Cart      </h1> 
        <a href="#home" data-icon="back">Back</a> 
    </div> 
