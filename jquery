    <!-- Footer --> 
    <div class="footer"> 
        <p><b>Mini Amazon</b></p> 
        <p>Electronics | Fashion | Deals</p> 
        <p>© 2026 All rights reserved</p> 
    </div> 
 
</div> 
</body> 
</html> 
 
Style.css 
/* Prevent horizontal scroll */ 
html, body { 
    margin: 0; 
    padding: 0; 
    overflow-x: hidden; 
    font-family: Arial; 
    background: #eaeaea; 
} 
/* Header */ 
.amazon-header { 
    background: #131921; 
    color: white; 
    padding: 10px; 
    text-align: center; 
} 
.search-box { 
    width: 90%; 
    padding: 8px; 
    margin-top: 8px; 
    border-radius: 5px; 
    border: none; 
} 
/* Banner */ 
.home-banner { 
    background: white; 
    margin: 10px; 
    padding: 10px; 
    border-radius: 8px; 
    text-align: center; 
} 
/* Grid */ 
.product-grid { 
    display: grid; 
    grid-template-columns: 1fr 1fr; 
    gap: 10px; 
    padding: 10px; 
} 
/* Product Card */ 
.product { 
    background: white; 
    padding: 10px; 
    border-radius: 10px; 
    text-align: center; 
    box-shadow: 0 2px 8px rgba(0,0,0,0.15); 
} 
/* Image Fix */ 
.product img { 
    width: 100%; 
    height: 120px; 
    object-fit: contain; 
} 
/* Text */ 
.product h4 { 
    font-size: 14px; 
    margin: 8px 0; 
} 
.product p { 
    color: #B12704; 
    font-weight: bold; 
} 
/* Button */ 
.product button { 
    background: #FFD814; 
    border: 1px solid #FCD200; 
    padding: 6px 10px; 
    border-radius: 5px; 
} 
/* Cart */ 
.cart-item { 
    background: white; 
    padding: 10px; 
    margin: 8px; 
    border-radius: 8px; 
} 
/* Make full height layout */ 
html, body { 
    height: 100%; 
    margin: 0; 
    padding: 0; 
    overflow-x: hidden; 
} 
 
/* Each page takes full screen */ 
[data-role="page"] { 
display: flex; 
flex-direction: column; 
min-height: 100vh; 
} 
/* Content should expand */ 
[data-role="content"] { 
flex: 1; 
} 
/* Sticky Footer */ 
.footer { 
background: #131921; 
color: white; 
text-align: center; 
padding: 12px; 
font-size: 12px;} 
